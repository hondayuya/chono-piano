---
import type { SiteSettings } from '../lib/types';
import { contactNav, primaryNav } from '../lib/nav';

type Props = {
  settings: SiteSettings;
  currentPath?: string;
};

const { settings, currentPath = '/' } = Astro.props;
const contactCurrent = currentPath === contactNav.href;
const revealOnScroll = currentPath === '/';
---

<header
  class:list={['site-header', revealOnScroll && 'site-header--reveal']}
  data-reveal-on-scroll={revealOnScroll ? 'true' : undefined}
>
  <div class="site-shell site-header__inner">
    <a class="brand-lockup" href="/">
      <span class="brand-lockup__main">{settings.companyName}</span>
      <span class="brand-lockup__sub">{settings.labName}</span>
    </a>

    <button
      class="site-header__toggle"
      type="button"
      aria-expanded="false"
      aria-controls="site-nav"
      data-nav-toggle
    >
      <span class="sr-only">メニューを開く</span>
      <span class="site-header__toggle-bars" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </span>
    </button>

    <div class="site-header__nav" id="site-nav" data-nav-panel>
      <nav aria-label="メインナビゲーション">
        <ul class="nav">
          {
            primaryNav.map((link) => (
              <li>
                <a
                  href={link.href}
                  aria-current={currentPath === link.href ? 'page' : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))
          }
          {
            settings.xUrl && (
              <li>
                <a href={settings.xUrl} target="_blank" rel="noopener noreferrer">
                  X
                </a>
              </li>
            )
          }
        </ul>
      </nav>
      <a
        class="button site-header__cta"
        href={contactNav.href}
        aria-current={contactCurrent ? 'page' : undefined}
      >
        {contactNav.label}
      </a>
    </div>
  </div>
</header>

<script>
  function initHeaderNav() {
    const header = document.querySelector('.site-header');
    const toggle = document.querySelector('[data-nav-toggle]');
    const panel = document.querySelector('[data-nav-panel]');
    if (!(header instanceof HTMLElement)) return;
    if (!(toggle instanceof HTMLButtonElement)) return;
    if (!(panel instanceof HTMLElement)) return;
    if (toggle.dataset.navReady === 'true') return;
    toggle.dataset.navReady = 'true';

    const label = toggle.querySelector('.sr-only');
    const revealOnScroll = header.dataset.revealOnScroll === 'true';
    const revealThreshold = 64;
    const desktopQuery = window.matchMedia('(min-width: 768px)');

    const updateReveal = () => {
      if (!revealOnScroll || !desktopQuery.matches) {
        header.classList.toggle('is-revealed', false);
        return;
      }
      const show =
        window.scrollY > revealThreshold || header.classList.contains('is-nav-open');
      header.classList.toggle('is-revealed', show);
    };

    const setOpen = (open) => {
      header.classList.toggle('is-nav-open', open);
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      if (label) {
        label.textContent = open ? 'メニューを閉じる' : 'メニューを開く';
      }
      document.body.classList.toggle('is-nav-locked', open);
      updateReveal();
    };

    toggle.addEventListener('click', () => {
      setOpen(!header.classList.contains('is-nav-open'));
    });

    panel.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') setOpen(false);
    });

    desktopQuery.addEventListener('change', () => {
      if (desktopQuery.matches) setOpen(false);
      updateReveal();
    });

    if (revealOnScroll) {
      updateReveal();
      window.addEventListener('scroll', updateReveal, { passive: true });
    }
  }

  initHeaderNav();
</script>
