---
import { excerptFromHtml, newsDisplayDate } from '../lib/microcms';
import type { News } from '../lib/types';

type Props = {
  items: News[];
  emptyText?: string;
};

const { items, emptyText = '現在お知らせはありません。' } = Astro.props;

function thumbUrl(url: string): string {
  const joiner = url.includes('?') ? '&' : '?';
  return `${url}${joiner}w=240&h=160&fit=crop`;
}
---

{
  items.length === 0 ? (
    <p>{emptyText}</p>
  ) : (
    <ul class="news-list">
      {items.map((item) => {
        const excerpt = excerptFromHtml(item.content);
        return (
          <li>
            <a href={`/news/${item.id}/`}>
              <div class="news-list__body">
                <span class="news-list__date">{newsDisplayDate(item)}</span>
                <span class="news-list__title">{item.title}</span>
                {excerpt && <p class="news-list__excerpt">{excerpt}</p>}
              </div>
              <div class="news-list__thumb" aria-hidden={!item.thumbnail}>
                {item.thumbnail ? (
                  <img
                    src={thumbUrl(item.thumbnail.url)}
                    alt=""
                    width="120"
                    height="80"
                    loading="lazy"
                  />
                ) : (
                  <span class="news-list__thumb-placeholder">チョウノウ調律所</span>
                )}
              </div>
            </a>
          </li>
        );
      })}
    </ul>
  )
}
