---
import type { Sound } from '../lib/types';

type Props = {
  sounds: Sound[];
  /** @deprecated Use sounds */
  works?: Sound[];
};

const { sounds: soundsProp, works } = Astro.props;
const sounds = soundsProp ?? works ?? [];
---

<div class="works-row" role="list">
  {
    sounds.length === 0 ? (
      <p>現在登録されている音源はありません。</p>
    ) : (
      sounds.map((sound) =>
        sound.url ? (
          <a
            class="work-tile"
            role="listitem"
            href={sound.url}
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="work-tile__media">
              {sound.thumbnail ? (
                <img
                  class="work-tile__thumb"
                  src={sound.thumbnail.url}
                  alt=""
                  width="320"
                  height="320"
                  loading="lazy"
                />
              ) : (
                <span class="work-tile__thumb work-tile__thumb--empty" aria-hidden="true" />
              )}
            </span>
            <span class="work-tile__title">{sound.title}</span>
          </a>
        ) : (
          <article class="work-tile" role="listitem">
            <span class="work-tile__media">
              {sound.thumbnail ? (
                <img
                  class="work-tile__thumb"
                  src={sound.thumbnail.url}
                  alt=""
                  width="320"
                  height="320"
                  loading="lazy"
                />
              ) : (
                <span class="work-tile__thumb work-tile__thumb--empty" aria-hidden="true" />
              )}
            </span>
            <span class="work-tile__title">{sound.title}</span>
          </article>
        ),
      )
    )
  }
</div>
