---
import LabBanner from './LabBanner.astro';
import { contactNav, footerSecondaryNav } from '../lib/nav';
import type { SiteSettings } from '../lib/types';

type Props = {
  settings: SiteSettings;
  currentPath?: string;
};

const { settings, currentPath = '/' } = Astro.props;

const labCurrent = currentPath === '/lab/' || currentPath.startsWith('/lab/');
const copyrightYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-shell">
    <div class="site-footer__row">
      <div class="site-footer__main">
        <p class="brand-lockup site-footer__brand">
          <span class="brand-lockup__main">{settings.companyName}</span>
          <span class="brand-lockup__sub">{settings.labName}</span>
        </p>

        <div class="site-footer__contact">
          {
            settings.address && (
              <p class="site-footer__line">{settings.address}</p>
            )
          }
          {
            (settings.phone || settings.fax) && (
              <p class="site-footer__tels">
                {settings.phone && (
                  <span class="site-footer__line">
                    TEL{' '}
                    <a href={`tel:${settings.phone.replace(/[^\d+]/g, '')}`}>
                      {settings.phone}
                    </a>
                  </span>
                )}
                {settings.fax && (
                  <span class="site-footer__line">
                    FAX{' '}
                    <a href={`tel:${settings.fax.replace(/[^\d+]/g, '')}`}>
                      {settings.fax}
                    </a>
                  </span>
                )}
              </p>
            )
          }
          <p class="site-footer__note">
            調律中はお電話に出られないことが多いため、留守番電話・ショートメールのご利用をお願いします。
          </p>
        </div>

        <div class="site-footer__inquiry">
          <p class="site-footer__inquiry-label">問い合わせ</p>
          <a class="button site-footer__inquiry-btn" href={contactNav.href}>
            相談・連絡シートへ
          </a>
        </div>
      </div>

      <div class="site-footer__lab">
        <LabBanner settings={settings} current={labCurrent} />
      </div>
    </div>

    <div class="site-footer__bottom">
      <div class="site-footer__meta">
        {
          footerSecondaryNav.map((link) => (
            <a class="site-footer__note-link" href={link.href}>
              {link.label}
            </a>
          ))
        }
        <p class="site-footer__copyright">
          © {copyrightYear} {settings.companyName} / {settings.labName}
        </p>
      </div>
      <p class="site-footer__top-wrap">
        <a class="site-footer__top" href="#top">ページの先頭へ戻る</a>
      </p>
    </div>
  </div>
</footer>
