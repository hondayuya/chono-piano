---
import LabBanner from './LabBanner.astro';
import type { SiteSettings } from '../lib/types';
import { contactNav, footerSecondaryNav, primaryNav } from '../lib/nav';

type Props = {
  settings: SiteSettings;
  currentPath?: string;
};

const { settings, currentPath = '/' } = Astro.props;

const navLinks = [...primaryNav, contactNav, ...footerSecondaryNav];
const labCurrent = currentPath === '/lab/' || currentPath.startsWith('/lab/');
---

<footer class="site-footer">
  <div class="site-shell">
    <LabBanner settings={settings} current={labCurrent} />

    <div class="site-footer__grid">
      <div>
        <p class="brand-lockup__main" style="font-size:1.15rem;margin:0 0 0.35rem">
          {settings.companyName}
        </p>
        <p style="margin:0">{settings.labName}</p>
      </div>
      <div>
        {
          settings.address && (
            <p style="margin:0 0 0.35rem">{settings.address}</p>
          )
        }
        {
          settings.phone && (
            <p style="margin:0 0 0.35rem">
              TEL{' '}
              <a href={`tel:${settings.phone.replace(/[^\d+]/g, '')}`}>
                {settings.phone}
              </a>
            </p>
          )
        }
        {
          settings.email && (
            <p style="margin:0">
              <a href={`mailto:${settings.email}`}>{settings.email}</a>
            </p>
          )
        }
      </div>
      <div>
        <nav class="footer-nav" aria-label="フッターナビゲーション">
          <ul>
            {
              navLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    aria-current={currentPath === link.href ? 'page' : undefined}
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
            {
              settings.xUrl && (
                <li>
                  <a href={settings.xUrl} target="_blank" rel="noopener noreferrer">
                    X
                  </a>
                </li>
              )
            }
          </ul>
        </nav>
        <p style="margin:1rem 0 0;font-size:0.88rem">
          調律中はお電話に出られないことが多いため、留守番電話・ショートメールのご利用をお願いします。
        </p>
        <p style="margin:0.75rem 0 0">
          <a class="button button--ghost site-footer__top" href="#top">ページの先頭へ戻る</a>
        </p>
      </div>
    </div>
  </div>
</footer>
