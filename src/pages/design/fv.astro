---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSiteSettings } from '../../lib/microcms';

const settings = await getSiteSettings();

const catchLines = ['あなたの演奏', '調律で損をして', 'いませんか？'] as const;
const leadLines = (
  settings.catchphrase ??
  '目の肥えたお客様にも応えてきた、\n確かな経験があります。'
).split(/\n/);
const lead = leadLines.join(' ');
const imageSrc = '/images/hero-tuning.webp';
const imageAlt = 'グランドピアノを調律する様子';

const patterns = [
  {
    id: '01',
    name: '全面・下左（現行）',
    note: 'フルブリード画像。テキストは下左。いまのトップに近い。',
  },
  {
    id: '02',
    name: '全面・下中央',
    note: '同じ全面画像で、キャッチを中央寄せ。',
  },
  {
    id: '03',
    name: '全面・中左',
    note: '縦位置を中央に。写真の余白と文のバランスを見る。',
  },
  {
    id: '04',
    name: '全面・上左',
    note: 'ヘッダー直後にコピーが来る配置。',
  },
  {
    id: '05',
    name: '左右分割・文左画右',
    note: '白地にコピー、右に写真（半面・高さ70%固定）。トップ採用のベース。',
  },
  {
    id: '06',
    name: '左右分割・画左文右',
    note: '写真を左半面（高さ70%固定）、右で説明する。',
  },
  {
    id: '07',
    name: '縦積み・文上画下',
    note: 'コピーを紙面で先に置き、下に全面写真。',
  },
  {
    id: '08',
    name: '縦積み・画上文下',
    note: '写真を先に見せ、下帯でコピー。',
  },
  {
    id: '09',
    name: '全面・大キャッチ',
    note: 'キャッチを大きく、リードは控えめ。',
  },
  {
    id: '10',
    name: '全面・低コントラスト',
    note: 'ベールを弱め、写真の気配を強く残す。',
  },
] as const;
---

<BaseLayout
  title="FVレイアウト検証"
  description="ファーストビューのレイアウト比較（開発用）"
  settings={settings}
  currentPath="/design/fv/"
  noindex={true}
>
  <div class="fv-lab site-shell">
    <header class="fv-lab__intro">
      <p class="fv-lab__eyebrow">Development</p>
      <h1 class="fv-lab__title">FVレイアウト検証</h1>
      <p class="fv-lab__lead">
        同じコピー・説明文・画像で、配置だけを変えた10パターンです。採用案の比較用（検索非公開）。
      </p>
      <p class="fv-lab__meta">
        キャッチ「{catchLines.join(' / ')}」／リード「{lead}」／
        <a href="/design/">デザインシステム</a>
        ／
        <a href="/">トップ（現行）</a>
      </p>
    </header>

    <div class="fv-lab__grid">
      {
        patterns.map((pattern) => (
          <article class="fv-lab__card" id={`pattern-${pattern.id}`}>
            <header class="fv-lab__card-head">
              <span class="fv-lab__num">{pattern.id}</span>
              <div>
                <h2 class="fv-lab__card-title">{pattern.name}</h2>
                <p class="fv-lab__card-note">{pattern.note}</p>
              </div>
            </header>

            <div
              class:list={['fv-frame', `fv-frame--${pattern.id}`]}
              aria-label={`パターン ${pattern.id}: ${pattern.name}`}
            >
              {(pattern.id === '01' ||
                pattern.id === '02' ||
                pattern.id === '03' ||
                pattern.id === '04' ||
                pattern.id === '09' ||
                pattern.id === '10') && (
                <>
                  <div class="fv-frame__media">
                    <img src={imageSrc} alt={imageAlt} width="1200" height="800" loading="lazy" />
                  </div>
                  <div class="fv-frame__veil" aria-hidden="true" />
                  <div class="fv-frame__content">
                    <h3 class="fv-frame__catch">
                      {catchLines.map((line) => (
                        <span class="fv-frame__catch-line">{line}</span>
                      ))}
                    </h3>
                    <p class="fv-frame__lead">
                      {leadLines.map((line) => (
                        <span class="fv-frame__lead-line">{line}</span>
                      ))}
                    </p>
                  </div>
                </>
              )}

              {(pattern.id === '05' || pattern.id === '06') && (
                <div class="fv-frame__split">
                  <div class="fv-frame__copy">
                    <h3 class="fv-frame__catch fv-frame__catch--ink">
                      {catchLines.map((line) => (
                        <span class="fv-frame__catch-line">{line}</span>
                      ))}
                    </h3>
                    <p class="fv-frame__lead fv-frame__lead--ink">
                      {leadLines.map((line) => (
                        <span class="fv-frame__lead-line">{line}</span>
                      ))}
                    </p>
                  </div>
                  <div class="fv-frame__media fv-frame__media--pane">
                    <img src={imageSrc} alt={imageAlt} width="1200" height="800" loading="lazy" />
                  </div>
                </div>
              )}

              {pattern.id === '07' && (
                <>
                  <div class="fv-frame__copy fv-frame__copy--band">
                    <h3 class="fv-frame__catch fv-frame__catch--ink">
                      {catchLines.map((line) => (
                        <span class="fv-frame__catch-line">{line}</span>
                      ))}
                    </h3>
                    <p class="fv-frame__lead fv-frame__lead--ink">
                      {leadLines.map((line) => (
                        <span class="fv-frame__lead-line">{line}</span>
                      ))}
                    </p>
                  </div>
                  <div class="fv-frame__media fv-frame__media--band">
                    <img src={imageSrc} alt={imageAlt} width="1200" height="800" loading="lazy" />
                  </div>
                </>
              )}

              {pattern.id === '08' && (
                <>
                  <div class="fv-frame__media fv-frame__media--band">
                    <img src={imageSrc} alt={imageAlt} width="1200" height="800" loading="lazy" />
                  </div>
                  <div class="fv-frame__copy fv-frame__copy--band">
                    <h3 class="fv-frame__catch fv-frame__catch--ink">
                      {catchLines.map((line) => (
                        <span class="fv-frame__catch-line">{line}</span>
                      ))}
                    </h3>
                    <p class="fv-frame__lead fv-frame__lead--ink">
                      {leadLines.map((line) => (
                        <span class="fv-frame__lead-line">{line}</span>
                      ))}
                    </p>
                  </div>
                </>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</BaseLayout>

<style>
  .fv-lab {
    padding: 4rem 0 8rem;
  }

  .fv-lab__intro {
    margin-bottom: 4rem;
    max-width: 72rem;
  }

  .fv-lab__eyebrow {
    margin: 0 0 0.8rem;
    font-size: 1.25rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  .fv-lab__title {
    margin: 0 0 1.2rem;
    font-size: clamp(2.8rem, 3.4vw, 3.6rem);
  }

  .fv-lab__lead {
    margin: 0 0 1.2rem;
    color: var(--ink-muted);
    font-size: var(--font-size-lead);
    line-height: 1.7;
  }

  .fv-lab__meta {
    margin: 0;
    font-size: 1.36rem;
    color: var(--ink-muted);
  }

  .fv-lab__grid {
    display: grid;
    gap: 4rem;
  }

  .fv-lab__card-head {
    display: flex;
    gap: 1.2rem;
    align-items: flex-start;
    margin-bottom: 1.2rem;
  }

  .fv-lab__num {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 3.2rem;
    height: 3.2rem;
    border: 1px solid var(--line);
    font-family: var(--font-display);
    font-size: 1.36rem;
    letter-spacing: 0.06em;
    color: var(--accent);
  }

  .fv-lab__card-title {
    margin: 0 0 0.4rem;
    font-size: 1.84rem;
  }

  .fv-lab__card-note {
    margin: 0;
    font-size: 1.36rem;
    color: var(--ink-muted);
  }

  .fv-frame {
    position: relative;
    isolation: isolate;
    display: grid;
    min-height: 36rem;
    overflow: hidden;
    border: 1px solid var(--line);
    background: var(--paper);
    color: #f7f4ef;
  }

  .fv-frame__media {
    position: absolute;
    inset: 0;
    z-index: -2;
  }

  .fv-frame__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 42%;
  }

  .fv-frame__veil {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(
      180deg,
      rgba(31, 26, 23, 0.18) 0%,
      rgba(31, 26, 23, 0.08) 35%,
      rgba(31, 26, 23, 0.55) 78%,
      rgba(31, 26, 23, 0.72) 100%
    );
    pointer-events: none;
  }

  .fv-frame__content {
    display: grid;
    gap: 1.2rem;
    align-content: end;
    padding: 3.2rem var(--gutter);
    max-width: 64rem;
  }

  .fv-frame__catch {
    margin: 0;
    display: grid;
    gap: 0.32rem;
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 2.8vw, 3.2rem);
    font-weight: 500;
    line-height: 1.4;
    letter-spacing: 0.06em;
    text-shadow: 0 0.2rem 1.6rem rgba(31, 26, 23, 0.4);
    font-feature-settings: var(--font-feature-display);
    font-variant-east-asian: proportional-width;
  }

  .fv-frame__catch-line {
    display: block;
  }

  .fv-frame__lead {
    margin: 0;
    max-width: 40rem;
    color: rgba(247, 244, 239, 0.9);
    font-size: 1.45rem;
    line-height: 1.7;
    letter-spacing: 0.04em;
  }

  .fv-frame__lead-line {
    display: block;
  }

  .fv-frame__catch--ink {
    color: var(--ink);
    text-shadow: none;
  }

  .fv-frame__lead--ink {
    color: var(--ink-muted);
  }

  /* 01 現行・下左 */
  .fv-frame--01,
  .fv-frame--02,
  .fv-frame--09,
  .fv-frame--10 {
    align-content: end;
  }

  /* 02 下中央 */
  .fv-frame--02 .fv-frame__content {
    justify-items: center;
    text-align: center;
    max-width: none;
    width: 100%;
    box-sizing: border-box;
  }

  .fv-frame--02 .fv-frame__lead {
    max-width: 44rem;
  }

  /* 03 中左 */
  .fv-frame--03 {
    align-content: center;
  }

  .fv-frame--03 .fv-frame__content {
    align-content: center;
  }

  .fv-frame--03 .fv-frame__veil {
    background: linear-gradient(
      90deg,
      rgba(31, 26, 23, 0.72) 0%,
      rgba(31, 26, 23, 0.35) 42%,
      rgba(31, 26, 23, 0.12) 100%
    );
  }

  /* 04 上左 */
  .fv-frame--04 {
    align-content: start;
  }

  .fv-frame--04 .fv-frame__content {
    align-content: start;
    padding-top: 3.2rem;
  }

  .fv-frame--04 .fv-frame__veil {
    background: linear-gradient(
      180deg,
      rgba(31, 26, 23, 0.7) 0%,
      rgba(31, 26, 23, 0.28) 40%,
      rgba(31, 26, 23, 0.1) 100%
    );
  }

  /* 05 / 06 左右分割（トップ採用案に近い） */
  .fv-frame--05,
  .fv-frame--06 {
    min-height: 0;
  }

  .fv-frame--05 .fv-frame__media,
  .fv-frame--06 .fv-frame__media {
    position: static;
  }

  .fv-frame__split {
    display: grid;
    grid-template-columns: minmax(0, 44fr) minmax(0, 56fr);
    align-items: center;
    min-height: 36rem;
  }

  .fv-frame--06 .fv-frame__split {
    direction: rtl;
  }

  .fv-frame--06 .fv-frame__split > * {
    direction: ltr;
  }

  .fv-frame__copy {
    display: grid;
    gap: 1.2rem;
    align-content: center;
    padding: 3.2rem clamp(2rem, 3vw, 3.6rem);
    background: var(--paper);
  }

  .fv-frame__media--pane {
    position: relative;
    width: 100%;
    height: 70%;
    min-height: 25.2rem;
    max-height: 25.2rem;
  }

  .fv-frame__media--pane img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 42%;
  }

  /* 07 / 08 縦積み */
  .fv-frame--07,
  .fv-frame--08 {
    display: grid;
    grid-template-rows: auto 1fr;
    min-height: 40rem;
  }

  .fv-frame--07 .fv-frame__media,
  .fv-frame--08 .fv-frame__media {
    position: relative;
    min-height: 24rem;
  }

  .fv-frame__copy--band {
    padding: 2.8rem var(--gutter);
  }

  .fv-frame__media--band img {
    min-height: 24rem;
  }

  /* 09 大キャッチ */
  .fv-frame--09 .fv-frame__catch {
    font-size: clamp(2.8rem, 4vw, 4rem);
    letter-spacing: 0.05em;
  }

  .fv-frame--09 .fv-frame__lead {
    font-size: 1.36rem;
    opacity: 0.92;
  }

  /* 10 低コントラスト */
  .fv-frame--10 .fv-frame__veil {
    background: linear-gradient(
      180deg,
      rgba(31, 26, 23, 0.08) 0%,
      rgba(31, 26, 23, 0.12) 45%,
      rgba(31, 26, 23, 0.42) 100%
    );
  }

  .fv-frame--10 .fv-frame__catch {
    text-shadow: 0 0.15rem 1.2rem rgba(31, 26, 23, 0.55);
  }

  @media (max-width: 767px) {
    .fv-frame {
      min-height: 28rem;
    }

    .fv-frame__split {
      grid-template-columns: 1fr;
      min-height: 0;
    }

    .fv-frame--06 .fv-frame__split {
      direction: ltr;
    }

    .fv-frame--06 .fv-frame__media--pane {
      order: -1;
    }

    .fv-frame__media--pane,
    .fv-frame__media--band {
      min-height: 20rem;
      max-height: 20rem;
      height: 20rem;
    }

    .fv-frame--07,
    .fv-frame--08 {
      min-height: 0;
    }
  }
</style>
