---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSiteSettings } from '../../lib/microcms';

const settings = await getSiteSettings();
---

<BaseLayout
  title="送信エラー"
  description="お問い合わせの送信に失敗しました"
  settings={settings}
  currentPath="/contact/"
  noindex={true}
>
  <div id="top" class="contact-page site-shell">
    <div class="contact-page__inner">
      <h1 class="section__title">送信に失敗しました</h1>
      <p class="section__lead">
        ご不便をおかけして申し訳ありません。時間をおいて再度お試しいただくか、お電話・メールにて直接ご連絡ください。
      </p>
      <div id="reason" class="notice notice--error" hidden></div>
      <div class="form-actions">
        <a class="button" href="/contact/">フォームに戻る</a>
        <a class="button button--ghost" href="/">トップページへ</a>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const code = params.get('code');
  const messages: Record<string, string> = {
    method: '不正なリクエストです。',
    csrf: 'セッションの有効期限が切れた可能性があります。フォームを開き直してください。',
    validation: '入力内容に不備があります。必須項目をご確認ください。',
    rate: '送信回数が上限に達しました。しばらく時間をおいてから再度お試しください。',
    mail: 'メール送信処理でエラーが発生しました。',
    origin: '不正な送信元からのリクエストです。',
    bot: '送信を受け付けられませんでした。',
  };

  if (code && messages[code]) {
    const el = document.getElementById('reason');
    if (el) {
      el.hidden = false;
      el.textContent = messages[code];
    }
  }
</script>
