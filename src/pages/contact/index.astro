---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSiteSettings } from '../../lib/microcms';

const settings = await getSiteSettings();
---

<BaseLayout
  title="ご相談・連絡シート"
  description="チョウノウ調律所への調律・修理・相談のご連絡シート"
  settings={settings}
  currentPath="/contact/"
>
  <div id="top" class="contact-page site-shell">
    <div class="contact-page__inner">
      <h1 class="section__title">ご相談・連絡シート</h1>
      <p class="section__lead">
        できるだけ詳細をご記入ください。訪問時間帯のご予約は基本的に電話で行います。電話番号はご相談後にメールでお伝えいただいても構いません。
      </p>

      <div id="form-status" class="form-status" aria-live="polite">送信準備中…</div>

      <form
        id="contact-form"
        class="contact-form"
        method="post"
        action="/contact/send.php"
        novalidate
        hidden
      >
        <input type="hidden" name="csrf_token" id="csrf_token" value="" />
        <input type="hidden" name="form_loaded_at" id="form_loaded_at" value="" />

        <div class="hp" aria-hidden="true">
          <label for="company_url">会社URL（入力しないでください）</label>
          <input
            type="text"
            id="company_url"
            name="company_url"
            tabindex="-1"
            autocomplete="off"
          />
        </div>

        <div class="field" data-field="name">
          <label for="name">お名前 <span class="req">必須</span></label>
          <input
            type="text"
            id="name"
            name="name"
            required
            maxlength="100"
            autocomplete="name"
            aria-describedby="name-error"
          />
          <p class="field__error" id="name-error" role="alert" hidden></p>
        </div>

        <div class="field" data-field="address">
          <label for="address">ご住所</label>
          <input
            type="text"
            id="address"
            name="address"
            maxlength="200"
            autocomplete="street-address"
            aria-describedby="address-error"
          />
          <p class="field__error" id="address-error" role="alert" hidden></p>
        </div>

        <div class="field" data-field="email">
          <label for="email">メールアドレス <span class="req">必須</span></label>
          <input
            type="email"
            id="email"
            name="email"
            required
            maxlength="200"
            autocomplete="email"
            inputmode="email"
            aria-describedby="email-error"
          />
          <p class="field__error" id="email-error" role="alert" hidden></p>
        </div>

        <div class="field" data-field="phone">
          <label for="phone">電話番号</label>
          <input
            type="tel"
            id="phone"
            name="phone"
            maxlength="30"
            autocomplete="tel"
            inputmode="tel"
            aria-describedby="phone-hint phone-error"
          />
          <span class="hint" id="phone-hint">
            ※訪問時間帯のご予約は基本電話で行います。電話番号はご相談後にメールでお伝えいただいても結構です。
          </span>
          <p class="field__error" id="phone-error" role="alert" hidden></p>
        </div>

        <div class="field" data-field="piano_maker">
          <label for="piano_maker">ピアノのメーカー</label>
          <input
            type="text"
            id="piano_maker"
            name="piano_maker"
            maxlength="100"
            aria-describedby="piano_maker-error"
          />
          <p class="field__error" id="piano_maker-error" role="alert" hidden></p>
        </div>

        <div class="field" data-field="piano_age">
          <label for="piano_age">ピアノの古さ（購入時期の目安）</label>
          <input
            type="text"
            id="piano_age"
            name="piano_age"
            maxlength="100"
            aria-describedby="piano_age-error"
          />
          <p class="field__error" id="piano_age-error" role="alert" hidden></p>
        </div>

        <div class="field" data-field="last_tuning">
          <label for="last_tuning">最後の調律時期</label>
          <input
            type="text"
            id="last_tuning"
            name="last_tuning"
            maxlength="100"
            aria-describedby="last_tuning-error"
          />
          <p class="field__error" id="last_tuning-error" role="alert" hidden></p>
        </div>

        <div class="field" data-field="message">
          <label for="message">ご相談内容 <span class="req">必須</span></label>
          <textarea
            id="message"
            name="message"
            required
            maxlength="5000"
            placeholder="音が出ない／出にくいキー、特にこうしてほしいこと、調律のみか修理希望か、以前の調律師についてなど"
            aria-describedby="message-error"
          ></textarea>
          <p class="field__error" id="message-error" role="alert" hidden></p>
        </div>

        <div class="form-actions">
          <button type="submit" class="button" id="submit-btn">送信する</button>
          <a class="button button--ghost" href="/">トップへ戻る</a>
        </div>
      </form>

      <div class="privacy">
        <p>
          送信内容は調律・修理のご相談対応の目的でのみ利用します。調律の狂いが大きい場合や修理が必要な場合は、別料金が発生することがあります。古いピアノでは調律時に弦が切れる場合があるため、現地確認後に説明する場合があります。
        </p>
        <p>
          原則として一度はお電話でお話しします。修理見積はメールでお送りし、承諾のご返信をいただく場合があります。
        </p>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const statusEl = document.getElementById('form-status');
  const tokenInput = document.getElementById('csrf_token') as HTMLInputElement | null;
  const loadedAtInput = document.getElementById('form_loaded_at') as HTMLInputElement | null;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;

  const LIMITS = {
    name: 100,
    address: 200,
    email: 200,
    phone: 30,
    piano_maker: 100,
    piano_age: 100,
    last_tuning: 100,
    message: 5000,
  } as const;

  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  const PHONE_RE = /^[0-9+\-()（）.\s　]{10,30}$/;
  const HEADER_INJECTION_RE = /[\r\n]/;

  type FieldName = keyof typeof LIMITS;

  const fieldNames = Object.keys(LIMITS) as FieldName[];

  const trimValue = (el: HTMLInputElement | HTMLTextAreaElement) => el.value.trim();

  const setError = (name: FieldName, message: string | null) => {
    const wrap = form?.querySelector(`[data-field="${name}"]`);
    const input = form?.elements.namedItem(name);
    const errorEl = document.getElementById(`${name}-error`);
    if (!(wrap instanceof HTMLElement) || !(errorEl instanceof HTMLElement)) return;

    const control =
      input instanceof HTMLInputElement || input instanceof HTMLTextAreaElement ? input : null;

    if (message) {
      wrap.classList.add('field--error');
      errorEl.hidden = false;
      errorEl.textContent = message;
      control?.setAttribute('aria-invalid', 'true');
    } else {
      wrap.classList.remove('field--error');
      errorEl.hidden = true;
      errorEl.textContent = '';
      control?.removeAttribute('aria-invalid');
    }
  };

  const validateField = (name: FieldName): boolean => {
    const el = form?.elements.namedItem(name);
    if (!(el instanceof HTMLInputElement || el instanceof HTMLTextAreaElement)) return true;

    const value = trimValue(el);
    const max = LIMITS[name];

    if (value.length > max) {
      setError(name, `${max}文字以内で入力してください。`);
      return false;
    }

    if ((name === 'name' || name === 'phone' || name === 'address') && HEADER_INJECTION_RE.test(value)) {
      setError(name, '改行を含めることはできません。');
      return false;
    }

    if (name === 'name') {
      if (value === '') {
        setError(name, 'お名前を入力してください。');
        return false;
      }
    }

    if (name === 'email') {
      if (value === '') {
        setError(name, 'メールアドレスを入力してください。');
        return false;
      }
      if (!EMAIL_RE.test(value)) {
        setError(name, '正しいメールアドレスの形式で入力してください。');
        return false;
      }
    }

    if (name === 'phone' && value !== '') {
      const digits = value.replace(/\D/g, '');
      if (digits.length < 10 || !PHONE_RE.test(value)) {
        setError(name, '電話番号の形式をご確認ください（例: 080-1234-5678）。');
        return false;
      }
    }

    if (name === 'message') {
      if (value === '') {
        setError(name, 'ご相談内容を入力してください。');
        return false;
      }
    }

    setError(name, null);
    return true;
  };

  const validateAll = (): boolean => {
    let ok = true;
    let firstInvalid: FieldName | null = null;
    for (const name of fieldNames) {
      if (!validateField(name)) {
        ok = false;
        if (!firstInvalid) firstInvalid = name;
      }
    }
    if (firstInvalid) {
      const el = form?.elements.namedItem(firstInvalid);
      if (el instanceof HTMLElement) el.focus();
    }
    return ok;
  };

  if (form && statusEl && tokenInput && loadedAtInput && submitBtn) {
    const showError = (message: string) => {
      statusEl.textContent = message;
      statusEl.className = 'notice notice--error';
      form.hidden = true;
    };

    for (const name of fieldNames) {
      const el = form.elements.namedItem(name);
      if (!(el instanceof HTMLInputElement || el instanceof HTMLTextAreaElement)) continue;
      el.addEventListener('blur', () => {
        validateField(name);
      });
      el.addEventListener('input', () => {
        const wrap = form.querySelector(`[data-field="${name}"]`);
        if (wrap?.classList.contains('field--error')) {
          validateField(name);
        }
      });
    }

    fetch('/contact/token.php', {
      method: 'GET',
      credentials: 'same-origin',
      headers: { Accept: 'application/json' },
    })
      .then((res) => {
        if (!res.ok) throw new Error('token');
        return res.json() as Promise<{ token?: string }>;
      })
      .then((data) => {
        if (!data?.token) throw new Error('token');
        tokenInput.value = data.token;
        loadedAtInput.value = String(Date.now());
        statusEl.textContent = '';
        statusEl.className = 'form-status';
        form.hidden = false;
      })
      .catch(() => {
        showError(
          'フォームを準備できませんでした。PHP が有効なサーバーで再度お試しください。',
        );
      });

    form.addEventListener('submit', (event) => {
      if (!validateAll()) {
        event.preventDefault();
        statusEl.textContent = '入力内容をご確認ください。';
        statusEl.className = 'form-status form-status--error';
        return;
      }

      statusEl.textContent = '';
      statusEl.className = 'form-status';
      submitBtn.disabled = true;
      submitBtn.textContent = '送信中…';
    });
  }
</script>
