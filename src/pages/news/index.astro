---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsList from '../../components/NewsList.astro';
import { getNewsList, getSiteSettings } from '../../lib/microcms';

const settings = await getSiteSettings();
const news = await getNewsList();
---

<BaseLayout
  title="お知らせ"
  description="チョウノウ調律所関連のお知らせと更新記事"
  settings={settings}
  currentPath="/news/"
>
  <div id="top" class="site-shell" style="padding:clamp(4rem,6vw,6.4rem) 0">
    <h1 class="section__title">お知らせ / 更新記事</h1>
    <p class="section__lead">
      チョウノウ調律所関連のお知らせと更新記事です。
    </p>
    <NewsList items={news} />
  </div>
</BaseLayout>
