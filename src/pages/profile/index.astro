---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { applyGlossaryLinks } from '../../lib/glossary';
import { getGlossary, getProfile, getSiteSettings } from '../../lib/microcms';

const settings = await getSiteSettings();
const profile = await getProfile();
const glossary = await getGlossary();

const biographyHtml = profile.biography.includes('<')
  ? profile.biography
  : `<p>${profile.biography}</p>`;
const biography = applyGlossaryLinks(biographyHtml, glossary);
---

<BaseLayout
  title="経歴・実績"
  description="張能康博の経歴・実績"
  settings={settings}
  currentPath="/profile/"
>
  <div id="top" class="site-shell" style="padding-top:clamp(4rem,6vw,6.4rem)">
    <h1 class="section__title">経歴・実績</h1>
    <p class="section__lead">調律に関わる経歴・施設・音源のまとめです。</p>
  </div>

  <section class="section">
    <div class="site-shell prose">
      <h2>{profile.name}の経歴</h2>
      {profile.birthText && <p>{profile.birthText}</p>}
      <div set:html={biography} />
    </div>
  </section>

  <section class="section">
    <div class="site-shell meta-grid">
      <div class="meta-block">
        <h3>録音スタジオ</h3>
        <p>{profile.studios}</p>
      </div>
      <div class="meta-block">
        <h3>ライブハウス</h3>
        <p>{profile.liveHouses}</p>
      </div>
      <div class="meta-block">
        <h3>CD・音源・ライブ</h3>
        <p>{profile.discographyNote}</p>
      </div>
    </div>
  </section>
</BaseLayout>
