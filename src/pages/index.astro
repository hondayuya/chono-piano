---
import BaseLayout from '../layouts/BaseLayout.astro';
import LabBanner from '../components/LabBanner.astro';
import NewsList from '../components/NewsList.astro';
import WorksRow from '../components/WorksRow.astro';
import {
  getLabArticles,
  getNewsList,
  getSiteSettings,
  getWorks,
} from '../lib/microcms';

const settings = await getSiteSettings();
const news = (await getNewsList(5)).slice(0, 5);
const works = await getWorks();
const labArticles = await getLabArticles();
const featuredLab = labArticles.find((a) => a.id.includes('chono-method-1')) ?? labArticles[0];

const heroLead = (settings.catchphrase ?? '')
  .replace(
    '目の肥えたお客様にも応えてきた、確かな経験があります。',
    '目の肥えたお客様にも応えてきた、\n確かな経験があります。',
  )
  .split(/\n/)
  .filter(Boolean);
---

<BaseLayout title={settings.companyName} settings={settings} currentPath="/">
  <div id="top"></div>
  <section class="hero hero--split" aria-label="メインビジュアル">
    <div class="hero__copy">
      <div class="hero__content">
        <h1 class="hero__catch">
          <span class="hero__catch-line">あなたの演奏</span>
          <span class="hero__catch-line">
            <mark class="hero__mark">調律で損</mark>をして
          </span>
          <span class="hero__catch-line">いませんか？</span>
        </h1>
        {
          heroLead.length > 0 && (
            <p class="hero__lead">
              {heroLead.map((line) => (
                <span class="hero__lead-line">{line}</span>
              ))}
            </p>
          )
        }
      </div>

      <div class="hero__bar">
        <p class="brand-lockup hero__brand">
          <span class="brand-lockup__main">{settings.companyName}</span>
          <span class="brand-lockup__sub">{settings.labName}</span>
        </p>
      </div>
    </div>

    <div class="hero__media">
      <img
        class="hero__image"
        src="/images/hero-tuning.webp"
        alt="グランドピアノを調律する様子"
        width="1200"
        height="1200"
        fetchpriority="high"
      />
      <div class="hero__lab">
        <LabBanner settings={settings} size="s" />
      </div>
    </div>
  </section>

  <section class="section" id="news">
    <div class="site-shell">
      <h2 class="section__title">お知らせ</h2>
      <p class="section__lead">直近のお知らせ・新記事をご案内します。</p>
      <NewsList items={news} />
      <p style="margin-top:2rem">
        <a href="/news/">お知らせ一覧へ</a>
      </p>
    </div>
  </section>

  <section class="section" id="about">
    <div class="site-shell">
      <h2 class="section__title">私と調律について</h2>
      <p class="section__lead">張能康博 — {settings.companyName}</p>
      <div class="prose">
        <p>{settings.aboutText}</p>
        {
          featuredLab && (
            <p>
              詳しくは
              <a href={`/lab/${featuredLab.id}/`}>「{featuredLab.title}」</a>
              をご覧ください。
            </p>
          )
        }
        <p>
          <a href="/profile/">経歴・実績</a>
        </p>
      </div>
    </div>
  </section>

  <section class="section" id="works">
    <div class="site-shell">
      <h2 class="section__title">調律した音源・動画リンク</h2>
      <p class="section__lead">
        LP・CDのジャケットや関連音源を紹介するエリアです（内容は microCMS で更新）。
      </p>
      <WorksRow works={works} />
    </div>
  </section>

  <section class="section" id="service">
    <div class="site-shell">
      <h2 class="section__title">業務内容</h2>
      <div class="prose">
        <p>{settings.businessText}</p>
      </div>
    </div>
  </section>

  <section class="section" id="fee">
    <div class="site-shell">
      <h2 class="section__title">調律料金・訪問可能地域</h2>
      <div class="meta-grid">
        <div class="meta-block">
          <h3>基本料金（税込）</h3>
          <p>グランドピアノ {settings.feeGp}</p>
          <p style="margin-top:0.8rem">アップライト {settings.feeUp}</p>
        </div>
        <div class="meta-block">
          <h3>訪問・出張</h3>
          <p>{settings.areaText}</p>
        </div>
      </div>
      <p style="margin-top:2.8rem">
        <a class="button" href="/contact/">相談・連絡シートへ</a>
      </p>
    </div>
  </section>
</BaseLayout>
