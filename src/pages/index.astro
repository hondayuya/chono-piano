---
import BaseLayout from '../layouts/BaseLayout.astro';
import LabBanner from '../components/LabBanner.astro';
import NewsList from '../components/NewsList.astro';
import Table from '../components/text/Table.astro';
import WorksRow from '../components/WorksRow.astro';
import {
  getLabArticles,
  getNewsList,
  getSiteSettings,
  getSounds,
} from '../lib/microcms';

const settings = await getSiteSettings();
const news = (await getNewsList(5)).slice(0, 5);
const sounds = await getSounds();
const labArticles = await getLabArticles();
const featuredLab = labArticles.find((a) => a.id.includes('chono-method-1')) ?? labArticles[0];

const heroLead = (settings.catchphrase ?? '')
  .replace(
    '目の肥えたお客様にも応えてきた、確かな経験があります。',
    '目の肥えたお客様にも応えてきた、\n確かな経験があります。',
  )
  .split(/\n/)
  .filter(Boolean);

const aboutSliderImages = [
  {
    src: '/images/about-slider/germany-workshop-templates.png',
    alt: 'ドイツの工房でピアノ部品の型と工具が並ぶ作業台',
  },
  {
    src: '/images/about-slider/germany-upright-iron-plates.png',
    alt: 'アップライトピアノの鋳造フレームが屋外に並ぶ様子',
  },
  {
    src: '/images/about-slider/germany-pin-template.png',
    alt: 'ピン配置の型紙と木製ガイドが置かれた作業台',
  },
  {
    src: '/images/about-slider/germany-grand-iron-plates.png',
    alt: 'グランドピアノの鋳造フレームが積み上げられた様子',
  },
  {
    src: '/images/about-slider/germany-workshop-mold.png',
    alt: '木材を曲げるための型が機械にセットされた様子',
  },
  {
    src: '/images/about-slider/germany-keyboard-action.png',
    alt: '鍵盤とアクション部品が並んだ工房の作業風景',
  },
  {
    src: '/images/about-slider/germany-upright-piano.png',
    alt: 'ドイツのアップライトピアノ',
  },
  {
    src: '/images/about-slider/germany-soundboard-bracing.png',
    alt: 'グランドピアノの響板と支柱構造',
  },
] as const;
---

<BaseLayout title={settings.companyName} settings={settings} currentPath="/">
  <div id="top"></div>
  <section class="hero hero--split" aria-label="メインビジュアル">
    <div class="hero__copy">
      <div class="hero__bar">
        <p class="brand-lockup hero__brand">
          <span class="brand-lockup__main">{settings.companyName}</span>
          <span class="brand-lockup__sub">{settings.labName}</span>
        </p>
      </div>

      <div class="hero__content">
        <h1 class="hero__catch">
          <span class="hero__catch-line">あなたの演奏</span>
          <span class="hero__catch-line">
            <mark class="hero__mark">調律で損</mark>をして
          </span>
          <span class="hero__catch-line">いませんか？</span>
        </h1>
        {
          heroLead.length > 0 && (
            <p class="hero__lead">
              {heroLead.map((line) => (
                <span class="hero__lead-line">{line}</span>
              ))}
            </p>
          )
        }
      </div>
    </div>

    <div class="hero__media">
      <img
        class="hero__image"
        src="/images/hero-tuning.webp"
        alt="グランドピアノを調律する様子"
        width="1200"
        height="1200"
        fetchpriority="high"
      />
      <div class="hero__lab">
        <LabBanner settings={settings} size="s" />
      </div>
    </div>
  </section>

  <section class="section" id="news">
    <div class="site-shell">
      <div class="section__head">
        <h2 class="section__title">お知らせ</h2>
        <a class="button" href="/news/">お知らせ一覧へ</a>
      </div>
      <NewsList items={news} />
    </div>
  </section>

  <section class="section section--about" id="about">
    <div class="site-shell">
      <h2 class="section__title">私と調律について</h2>
      <p class="section__lead">張能康博 — {settings.companyName}</p>
      <div class="about-layout">
        <div class="about-layout__copy">
          <div class="prose">
            {
              (settings.aboutText ?? '')
                .split(/\n\n+/)
                .filter(Boolean)
                .map((paragraph) => <p>{paragraph}</p>)
            }
          </div>
          <div class="section__actions">
            <a class="button" href="/profile/">経歴・実績を見る</a>
            {
              featuredLab && (
                <a class="button button--lab" href={`/lab/${featuredLab.id}/`}>
                  チョウノウ方式について
                </a>
              )
            }
          </div>
        </div>
        <figure class="about-layout__media">
          <img
            src="/images/about-tuner-at-work.png"
            alt="ピアノを調律する張能康博"
            width="800"
            height="800"
            loading="lazy"
            decoding="async"
          />
        </figure>
      </div>
    </div>

    <div class="about-marquee" aria-label="ドイツでの調律・製作に関する写真">
      <div class="about-marquee__track">
        {
          [0, 1].map((copy) => (
            <div class="about-marquee__group" aria-hidden={copy === 1 ? 'true' : undefined}>
              {aboutSliderImages.map((image) => (
                <figure class="about-marquee__item">
                  <img
                    src={image.src}
                    alt={copy === 0 ? image.alt : ''}
                    width="640"
                    height="400"
                    loading="lazy"
                    decoding="async"
                  />
                </figure>
              ))}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section" id="works">
    <div class="site-shell">
      <h2 class="section__title">調律した音源・動画リンク</h2>
      <p class="section__lead">
        LP・CDのジャケットや関連音源を紹介するエリアです（内容は microCMS で更新）。
      </p>
      <WorksRow sounds={sounds} />
    </div>
  </section>

  <section class="section" id="service">
    <div class="site-shell">
      <h2 class="section__title">ご依頼について</h2>
      <div class="prose">
        <p>{settings.businessText}</p>
      </div>
      <div class="meta-grid">
        <div class="meta-block">
          <h3>調律基本料金</h3>
          <Table caption="税込価格">
            <thead>
              <tr>
                <th scope="col">区分</th>
                <th scope="col">料金</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>グランドピアノ</td>
                <td>{settings.feeGp}</td>
              </tr>
              <tr>
                <td>アップライト</td>
                <td>{settings.feeUp}</td>
              </tr>
            </tbody>
          </Table>
        </div>
        <div class="meta-block">
          <h3>訪問・出張</h3>
          <p>{settings.areaText}</p>
        </div>
      </div>
      <div class="section__actions">
        <a class="button" href="/contact/">相談・連絡シートへ</a>
      </div>
    </div>
  </section>
</BaseLayout>
