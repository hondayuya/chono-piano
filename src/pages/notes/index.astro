---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getGlossaryWithUsages } from '../../lib/glossary-pages';
import { getSiteSettings } from '../../lib/microcms';

const settings = await getSiteSettings();
const { glossary, usages } = await getGlossaryWithUsages();

function initialGroup(term: string): string {
  return term.charAt(0);
}

const grouped = glossary.reduce<Record<string, typeof glossary>>((acc, item) => {
  const key = initialGroup(item.reading || item.term);
  acc[key] ??= [];
  acc[key].push(item);
  return acc;
}, {});
---

<BaseLayout
  title="注釈"
  description="サイト内記事の注釈・解説"
  settings={settings}
  currentPath="/notes/"
>
  <div id="top" class="notes-page site-shell">
    <h1 class="section__title">注釈・解説</h1>
    <p class="section__lead">
      本文中の語彙の解説です。各項目から、その言葉が使われているページへ移動できます。
    </p>
    {
      glossary.length === 0 ? (
        <p>現在、注釈はありません。</p>
      ) : (
        <div class="glossary-list">
          {Object.entries(grouped).map(([key, items]) => (
            <section class="glossary-group">
              <h2 class="glossary-group__initial">{key}</h2>
              <dl class="glossary-group__body stack">
                {items.map((item) => {
                  const refs = usages[item.id] ?? [];
                  return (
                    <div class="glossary-entry" id={item.id}>
                      <dt class="glossary-entry__term">
                        {item.term}
                        {item.reading && (
                          <span class="glossary-entry__reading">{item.reading}</span>
                        )}
                      </dt>
                      <dd class="glossary-entry__body">{item.body}</dd>
                      {refs.length > 0 && (
                        <dd class="glossary-refs">
                          <span class="glossary-refs__label">使用ページ</span>
                          <ul>
                            {refs.map((ref) => (
                              <li>
                                <a href={ref.href}>{ref.title}</a>
                              </li>
                            ))}
                          </ul>
                        </dd>
                      )}
                    </div>
                  );
                })}
              </dl>
            </section>
          ))}
        </div>
      )
    }
  </div>
</BaseLayout>
