---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { resolveBreadcrumbs, type BreadcrumbItem } from '../lib/breadcrumb';
import { googleFonts, xserverWebfont } from '../lib/fonts';
import type { SiteSettings } from '../lib/types';

type Props = {
  title: string;
  description?: string;
  settings: SiteSettings;
  currentPath?: string;
  noindex?: boolean;
  /** ホーム以降のパンくず。未指定時は currentPath から自動生成 */
  breadcrumbs?: BreadcrumbItem[];
};

const {
  title,
  description = 'チョウノウ調律所 / Labo CHONO — ピアノ調律・修理・調整のご相談',
  settings,
  currentPath = '/',
  noindex = false,
  breadcrumbs: breadcrumbTrail,
} = Astro.props;

const pageTitle =
  title === settings.companyName
    ? `${settings.companyName} / ${settings.labName}`
    : `${title} | ${settings.companyName}`;

const breadcrumbItems = resolveBreadcrumbs(currentPath, breadcrumbTrail);
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <link rel="preconnect" href={googleFonts.preconnect[0]} />
    <link rel="preconnect" href={googleFonts.preconnect[1]} crossorigin />
    <link rel="stylesheet" href={googleFonts.stylesheetHref} />

    <title>{pageTitle}</title>
    <script is:inline type="text/javascript" src={xserverWebfont.scriptSrc}></script>
  </head>
  <body>
    <Header settings={settings} currentPath={currentPath} />
    {breadcrumbItems && <Breadcrumb items={breadcrumbItems} />}
    <main>
      <slot />
    </main>
    <Footer settings={settings} currentPath={currentPath} />
  </body>
</html>
