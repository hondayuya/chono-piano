# microCMS（ビルド時・サーバー側のみ。PUBLIC_ にしない）
MICROCMS_SERVICE_DOMAIN=your-service-domain
MICROCMS_API_KEY=your-api-key

# true のとき microCMS を呼ばず src/mocks/*.json を使う（開発用）
# USE_LOCAL_MOCK=true

# Public site URL (no trailing slash) — used in meta / sitemap if needed
PUBLIC_SITE_URL=https://chono-piano.com
